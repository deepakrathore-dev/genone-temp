# ══════════════════════════════════════════════════════════════════════════════
# Backend environment template
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#   3. .env is gitignored — never commit it
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────────────────────────
# Local example:
#   DATABASE_URL=postgresql://postgres:your_password@localhost:5432/genone_local
# Staging example:
#   DATABASE_URL=postgresql://genone_db_user:STAGING_PASSWORD@genone-staging-postgres.cl4cuo86eg9i.us-east-2.rds.amazonaws.com:5432/genone_staging
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=genone_local
