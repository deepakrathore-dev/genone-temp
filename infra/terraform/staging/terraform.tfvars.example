# ══════════════════════════════════════════════════════════════════════════════
# terraform.tfvars.example
#
# HOW TO USE:
#   1. Copy this file:  cp terraform.tfvars.example terraform.tfvars
#   2. Fill in your real values in terraform.tfvars
#   3. Never commit terraform.tfvars (it's in .gitignore)
# ══════════════════════════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────────────────────────
project_name = "genone"
environment  = "staging"
aws_region   = "us-east-2"

# ── Network ───────────────────────────────────────────────────────────────────
# Usually no reason to change these defaults
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidr    = "10.0.1.0/24"
private_subnet_1_cidr = "10.0.2.0/24"
private_subnet_2_cidr = "10.0.3.0/24"

# ── EC2 — ★ COST LEVER ────────────────────────────────────────────────────────
# t3.micro  = ~$7.50/mo  (free tier, tight)
# t3.small  = ~$15/mo    (recommended for staging)
# t3.medium = ~$30/mo    (if containers feel slow)
ec2_instance_type = "t3.small"
ec2_volume_size   = 20
ec2_volume_type   = "gp3"

# Get your public key: cat ~/.ssh/id_rsa.pub  (or id_ed25519.pub)
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... your-key-here"

# Restrict to your office/home IP for security: "YOUR.IP.ADDRESS/32"
# Leave as 0.0.0.0/0 only if you don't have a fixed IP
ssh_allowed_cidr = "0.0.0.0/0"

# ── RDS — ★ COST LEVER ────────────────────────────────────────────────────────
# db.t3.micro  = ~$13/mo  (free tier, fine for staging)
# db.t3.small  = ~$25/mo
# db.t3.medium = ~$52/mo
rds_instance_class        = "db.t3.micro"
rds_allocated_storage     = 20
rds_engine_version        = "16"
rds_multi_az              = false
rds_backup_retention_days = 7
rds_deletion_protection   = false

# ── Database Credentials ──────────────────────────────────────────────────────
# Use a strong password — min 8 chars, mix of letters/numbers/symbols
db_name     = "genone_staging"
db_username = "genone_admin"
db_password = "REPLACE_WITH_STRONG_PASSWORD_MIN_8_CHARS"
